[global]
    # Display
    monitor = 0
    follow = mouse

    # Geometry
    width = 380
    height = 200
    origin = top-right
    offset = 20x20
    scale = 0
    notification_limit = 5

    # Layout
    gap_size = 6
    padding = 12
    horizontal_padding = 16
    text_icon_padding = 12
    frame_width = 2
    separator_height = 1
    corner_radius = 8

    # Borders
    frame_color = "#3c3836"
    separator_color = "#3c3836"

    # Progress bar
    progress_bar = true
    progress_bar_height = 6
    progress_bar_frame_width = 0
    progress_bar_min_width = 150
    progress_bar_max_width = 340
    progress_bar_corner_radius = 3
    progress_bar_bar_color = "#fabd2f"
    progress_bar_frame_color = "#3c3836"

    # Text
    font = Lexend 11
    line_height = 2
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes
    word_wrap = yes

    # Icons
    enable_recursive_icon_lookup = true
    icon_theme = Papirus-Dark
    icon_position = left
    min_icon_size = 24
    max_icon_size = 32

    # History
    sticky_history = yes
    history_length = 20

    # Misc / behavior
    dmenu = /usr/bin/fuzzel -d
    browser = /usr/bin/xdg-open
    always_run_script = true
    title = Dunst
    class = Dunst
    ignore_dbusclose = false
    force_xwayland = false
    force_xinerama = false

    # Mouse
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[experimental]
    per_monitor_dpi = false

[urgency_low]
    background = "#282828"
    foreground = "#a89984"
    frame_color = "#3c3836"
    timeout = 5

[urgency_normal]
    background = "#282828"
    foreground = "#ebdbb2"
    frame_color = "#3c3836"
    timeout = 10

[urgency_critical]
    background = "#282828"
    foreground = "#ebdbb2"
    frame_color = "#fb4934"
    timeout = 0
    # Critical notifications persist until dismissed
